{
  "name": "avlo",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "worker",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:worker": "wrangler dev --port 8787",
    "dev:client": "npm run dev -w client",
    "dev:p": "concurrently \"npm run dev:p:worker\" \"npm run dev:p:client\"",
    "dev:p:worker": "wrangler dev --port 8788",
    "dev:p:client": "VITE_PORT=3001 WORKER_PORT=8788 npm run dev -w client",
    "dev:old": "npm run dev -w client",
    "build": "npm run build -w client",
    "preview": "concurrently \"npm run dev:worker\" \"npm run preview -w client\"",
    "deploy": "wrangler deploy",
    "typecheck": "npm run -w packages/shared build:types && npm run -w client typecheck && npm run -w worker typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251106.1",
    "@rollup/rollup-linux-x64-gnu": "^4.46.3",
    "@types/node": "^22.13.4",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "wrangler": "^4.46.0"
  },
  "dependencies": {
    "chalk": "^5.6.0",
    "partyserver": "^0.3.3",
    "y-leveldb": "^0.2.0",
    "y-partyserver": "^2.1.3"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
