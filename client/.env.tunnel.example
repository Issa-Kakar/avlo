# Cloudflare Tunnel Configuration Example
# Copy this to .env.local when using Cloudflare tunnel
#
# IMPORTANT: This configuration is ONLY needed when using Cloudflare tunnel to expose your local dev to the internet.
# For normal local development, use the default .env.local settings.

# Default settings (same as regular .env.local)
VITE_WS_BASE=/ws
VITE_API_BASE=/api
VITE_ROOM_TTL_DAYS=14

# Cloudflare Tunnel Setup Instructions:
# 1. Start your local development servers:
#    npm run dev (starts client on 3000, server on 3001)
#
# 2. In a new terminal, create a tunnel for the CLIENT (port 3000):
#    cloudflared tunnel --url localhost:3000
#    Example output: https://quick-random-name.trycloudflare.com
#
# 3. In another terminal, create a tunnel for the SERVER (port 3001):
#    cloudflared tunnel --url localhost:3001
#    Example output: https://server-random-name.trycloudflare.com
#
# 4. Set the VITE_WS_URL below to the SERVER tunnel URL + /ws:
#    VITE_WS_URL=wss://server-random-name.trycloudflare.com/ws
#
# 5. Copy this configuration to .env.local:
#    cp .env.tunnel.example .env.local
#
# 6. Restart the client dev server to pick up the new config:
#    Ctrl+C then npm run dev -w client
#
# 7. Access your app through the CLIENT tunnel URL

# IMPORTANT: Uncomment and update this with your SERVER tunnel URL when using Cloudflare tunnel
# VITE_WS_URL=wss://YOUR-SERVER-TUNNEL-URL.trycloudflare.com/ws

# Example (replace with your actual server tunnel URL):
# VITE_WS_URL=wss://server-quick-random.trycloudflare.com/ws

# Note: When you're done with tunneling and want to go back to local development:
# 1. Remove or comment out the VITE_WS_URL line
# 2. Restart the client dev server
# OR just restore your original .env.local file