# ============================================
# AVLO CONFIGURATION
# All constants can be overridden via environment variables
# Defaults are defined in shared/config.ts
# ============================================

# Basic Server Configuration
NODE_ENV=development
PORT=3001

# ============================================
# ROOM & PERSISTENCE (Phase 5+)
# ============================================
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://user:password@localhost:5432/avlo
# ROOM_TTL_DAYS=14
# ROOM_SIZE_WARNING_BYTES=8388608    # 8 MB
# ROOM_SIZE_READONLY_BYTES=10485760  # 10 MB
# MAX_CLIENTS_PER_ROOM=105
# MAX_CONCURRENT_PER_IP=8
# MAX_INBOUND_FRAME_BYTES=2097152    # 2 MB
# GZIP_LEVEL=4

# ============================================
# STROKE & DRAWING (Phase 3+)
# ============================================
# MAX_POINTS_PER_STROKE=10000
# MAX_TOTAL_STROKES=5000
# PEN_SIMPLIFICATION_TOLERANCE=0.8
# HIGHLIGHTER_SIMPLIFICATION_TOLERANCE=0.5
# MAX_ENCODED_UPDATE_BYTES=131072    # 128 KB

# ============================================
# WEBRTC & AWARENESS (Phase 4+)
# ============================================
# Y_SIGNALING_URLS=wss://signaling.yjs.dev,wss://your-signaling.com
# Y_TURN_URL=turns:turn.example.com:443?transport=tcp
# Y_TURN_USER=username
# Y_TURN_PASS=password
# Y_RTC_PASSWORD_SALT=avlo-rtc-salt
# MAX_WEBRTC_PEERS=15
# WEBRTC_START_THRESHOLD=12
# AWARENESS_HZ_BASE_RTC=25
# AWARENESS_HZ_BASE_WS=15

# ============================================
# RATE LIMITING (Phase 5+)
# ============================================
# ROOMS_PER_HOUR_PER_IP=10
# ROOM_RENAMES_PER_MINUTE=5
# CLEAR_BOARD_COOLDOWN_MS=15000
# TTL_EXTEND_COOLDOWN_MS=600000      # 10 minutes

# ============================================
# PERFORMANCE & RENDERING (Phase 3+)
# ============================================
# MAX_FPS=60
# HIDDEN_TAB_FPS=8
# RENDER_BUDGET_MS=16
# EXPORT_MAX_EDGE_PX=8192
# EXPORT_TIMEOUT_MS=2000
# MIN_ZOOM=0.1
# MAX_ZOOM=10

# ============================================
# CODE EXECUTION (Phase 7+)
# ============================================
# MAX_CODE_BODY_BYTES=204800         # 200 KB
# MAX_OUTPUT_BYTES_PER_RUN=10240     # 10 KB
# CODE_EXECUTION_TIMEOUT_MS=5000

# ============================================
# BACKOFF & RETRY SETTINGS
# ============================================
# WS_BACKOFF_BASE_MS=300
# WS_BACKOFF_MAX_MS=20000
# RTC_BACKOFF_BASE_MS=1000
# RTC_BACKOFF_MAX_MS=30000

# ============================================
# PWA & SERVICE WORKER (Phase 8+)
# ============================================
# AVATARS_CACHE_MAX_ENTRIES=400
# MEDIA_CACHE_MAX_ENTRIES=300
# MIN_FREE_STORAGE_MB=200

# ============================================
# MONITORING & OBSERVABILITY (Phase 10+)
# ============================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# ALLOWED_ORIGINS=http://localhost:3000,https://avlo.app

# ============================================
# DEBUG FLAGS (Development)
# ============================================
# DEBUG_MODE=true
# ENABLE_PROFILING=false
# FORCE_OFFLINE=false
# FORCE_READONLY=false
# DISABLE_WEBRTC=false
