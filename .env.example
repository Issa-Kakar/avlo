# Database connection string for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/avlo?schema=public"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# Server configuration
NODE_ENV="development"
PORT="3000"

# Origin allowlist (comma-separated absolute origins)
ORIGIN_ALLOWLIST="http://localhost:5173,http://localhost:3000"

# Room TTL in days (default: 14)
ROOM_TTL_DAYS="14"

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=""

# Application version (used for PWA updates)
APP_VERSION="1.0.0"
