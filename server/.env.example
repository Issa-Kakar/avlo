# ============================================
# AVLO SERVER CONFIGURATION
# Phase 6 (Current) Requirements
# ============================================

# Basic Server
NODE_ENV=development
PORT=3001

# ============================================
# REQUIRED FOR PHASE 6
# ============================================

# Database connections (required)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/avlo

# CORS Origins (comma-separated)
ORIGIN_ALLOWLIST=http://localhost:5173,http://localhost:3000

# Room configuration
ROOM_TTL_DAYS=14
WS_MAX_FRAME_BYTES=2000000
MAX_CLIENTS_PER_ROOM=105
GZIP_LEVEL=4

# ============================================
# OPTIONAL OVERRIDES (have defaults in shared/config.ts)
# ============================================
# ROOM_SIZE_WARNING_BYTES=13631488    # 13 MB
# ROOM_SIZE_READONLY_BYTES=15728640   # 15 MB
# MAX_CONCURRENT_PER_IP=8
# MAX_INBOUND_FRAME_BYTES=2097152     # 2 MB

# ============================================
# FUTURE PHASES (DO NOT SET YET)
# ============================================

# === Phase 7: Awareness ===
# AWARENESS_HZ_BASE_WS=15

# === Phase 15: Code Execution ===
# MAX_CODE_BODY_BYTES=204800
# MAX_OUTPUT_BYTES_PER_RUN=10240
# CODE_EXECUTION_TIMEOUT_MS=5000

# === Phase 16: PWA ===
# AVATARS_CACHE_MAX_ENTRIES=400
# MEDIA_CACHE_MAX_ENTRIES=300

# === Phase 17: WebRTC ===
# Y_SIGNALING_URLS=wss://signaling.yjs.dev
# Y_TURN_URL=turns:turn.example.com:443?transport=tcp
# Y_TURN_USER=username
# Y_TURN_PASS=password
# Y_RTC_PASSWORD_SALT=avlo-rtc-salt
# MAX_WEBRTC_PEERS=15

# === Later: Monitoring ===
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id